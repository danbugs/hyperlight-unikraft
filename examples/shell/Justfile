# shell on Hyperlight
#
# just run      - Run once
# just run-5    - Run 5x (snapshot/restore)
# just rootfs   - Build rootfs via Docker (cross-platform)
# just build    - Build Unikraft kernel via kraft
# just rebuild  - Clean and rebuild kernel + rootfs
# just clean    - Remove build artifacts

set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]
export DOCKER_BUILDKIT := "0"

kernel    := ".unikraft/build/shell-hyperlight_hyperlight-x86_64"
initrd    := "initrd.cpio"
memory    := "16Mi"
image     := "shell-hyperlight"

# Run the example
run:
    hyperlight-unikraft {{kernel}} --initrd {{initrd}} --memory {{memory}} -- /demo.sh

# Run 5 times via snapshot/restore
run-5:
    hyperlight-unikraft {{kernel}} --initrd {{initrd}} --repeat 4 --memory {{memory}} -- /demo.sh

# Build rootfs via Docker (no host cpio/musl-gcc needed)
rootfs:
    docker build --platform linux/amd64 --target cpio -t {{image}}-cpio .
    docker rm -f {{image}}-tmp || true
    docker create --name {{image}}-tmp {{image}}-cpio /bin/true
    docker cp {{image}}-tmp:/output.cpio ./{{initrd}}
    docker rm -f {{image}}-tmp

# Build Unikraft kernel via kraft
build:
    -kraft-hyperlight build --plat hyperlight --arch x86_64

# Full clean rebuild
rebuild: clean build rootfs

# Clean build artifacts
[unix]
clean:
    rm -rf .unikraft {{initrd}}

[windows]
clean:
    if (Test-Path .unikraft) { Remove-Item -Recurse -Force .unikraft }
    if (Test-Path {{initrd}}) { Remove-Item -Force {{initrd}} }
